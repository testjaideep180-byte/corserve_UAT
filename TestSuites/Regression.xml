<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Test Suite">
    <listeners>
        <listener class-name= "TestComponents.Listeners"/>
    </listeners>
    <test verbose="2" preserve-order="true" name="D:/Selenium Script/Corserve_UAT">
        <classes>
            <class name="Tests.CartTest">
                <methods>
                    <include name="verifyProceedToCheckoutFunctionality"/>
                    <include name="verifyRemoveInvoiceFromCartFunctionality"/>
                    <include name="verifyTotalInvoiceAmount"/>
                    <include name="verifyAddMoreInvoiceCTAFunctionality"/></methods>
            </class>
            <class name="Tests.InvoiceTest">
                <methods>
                    <include name="verifyInvoiceSearchFunctionality"/>
                    <include name="verifyInvoicePaymentFunctionality"/>
                    <include name="verifyInvoiceCardPaymentFunctionality"/>
                    <include name="verifyCartClearFunctionality"/>
                    <include name="verifyInvoiceCardCartFunctionality"/>
                    <include name="verifyViewInvoiceDetailsFunctionality"/></methods>
            </class>
            <class name="Tests.LoginTest">
                <methods>
                    <include name="verifyLoginFunctionality"/>
                    <include name="verifyLoginWithInvalidCredentialsFunctionality"/>
                    <include name="verifyLoginWithoutCredentials"/>
                    <include name="verifyLoginWithInvalidCustomerIDFormat"/>
                    <include name="verifyRedirectionToInvoiceList"/>
                    <include name="verifyFindInvoice"/>
                </methods>
            </class>
            <class name="Tests.ProfileTest">
                <methods>
                    <include name="verifyUpdateProfileFunctionality"/>
                    <include name="verifyUpdateProfileFunctionalityWithoutDetails"/>
                </methods>
            </class>
            <class name="Tests.RegistrationTest">
                <methods>
                    <include name="registrationFailure"/>
                    <include name="emptyFormSubmission"/>
                    <include name="verifySigUpBtnFunctionality"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>